class Solution {
  public:
    void pushZerosToEnd(vector<int>& arr) {
        // code here
        int j=0;
        for(int i=0;i<size(arr);i++)
        {
            if(arr[i]!=0)
            {
                if(i!=j)
                  swap(arr[i],arr[j]);
                j++;
            }
        }
    }
};
